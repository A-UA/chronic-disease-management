# Security — 必须设置，用于 JWT 签名
JWT_SECRET=replace-with-a-secure-random-string

LLM_PROVIDER=xiaomi_mimo
CHAT_MODEL=mimo-v2-flash
LLM_BASE_URL=https://api.xiaomimimo.com/v1
LLM_API_KEY=replace-with-your-mimo-key

RERANKER_PROVIDER=xiaomi_mimo
RERANKER_MODEL=mimo-v2-flash
RERANKER_BASE_URL=
RERANKER_API_KEY=

# Xiaomi MiMo currently does not expose a working embeddings endpoint for this project.
# Use a separate provider for embeddings, for example ZhipuAI or OpenAI official embeddings.
EMBEDDING_PROVIDER=zhipu
EMBEDDING_MODEL=embedding-3
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
EMBEDDING_API_KEY=replace-with-your-zhipu-key
# OR for OpenAI official embeddings:
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=replace-with-your-openai-key
