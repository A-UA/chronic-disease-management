# Security — 必须设置，用于 JWT 签名
JWT_SECRET=replace-with-a-secure-random-string
API_KEY_SALT=replace-with-a-secure-random-string-for-api-key-hashing

# ── AI 通用配置（LLM / Embedding / Reranker 的共享回退配置）──
LLM_BASE_URL=https://api.xiaomimimo.com/v1
LLM_API_KEY=replace-with-your-api-key
CHAT_MODEL=mimo-v2-flash

# ── Embedding（留空则回退到 LLM_* 配置）──
# 如果 Embedding 与 LLM 用同一厂商，以下可全部留空
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
EMBEDDING_API_KEY=replace-with-your-zhipu-key
EMBEDDING_MODEL=embedding-3
# 切换厂商示例（只需改 BASE_URL + API_KEY + MODEL，无需改代码）：
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_MODEL=text-embedding-3-small

# ── Reranker（noop=不重排序 / simple=简单打分 / 其他=OpenAI-compatible 服务）──
RERANKER_PROVIDER=noop
# RERANKER_BASE_URL=
# RERANKER_API_KEY=
# RERANKER_MODEL=

# ── 常见厂商 BASE_URL 速查 ──
# OpenAI      https://api.openai.com/v1
# 智谱 GLM    https://open.bigmodel.cn/api/paas/v4/
# 通义千问    https://dashscope.aliyuncs.com/compatible-mode/v1
# DeepSeek    https://api.deepseek.com/v1
# Moonshot    https://api.moonshot.cn/v1
# 硅基流动    https://api.siliconflow.cn/v1
# 火山引擎    https://ark.cn-beijing.volces.com/api/v3
# 小米 MiMo   https://api.xiaomimimo.com/v1
